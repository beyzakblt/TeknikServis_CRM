<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Teknik CRM Admin</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <style>
            :root {
                --sidebar-bg: #1e293b;
                --sidebar-hover: #334155;
                --primary-color: #3b82f6;
            }

            body {
                font-family: 'Inter', sans-serif;
                background-color: #f1f5f9;
            }

            /* Sidebar Stil */
            #sidebar {
                min-width: 260px;
                max-width: 260px;
                background: var(--sidebar-bg);
                color: #fff;
                transition: all 0.3s;
                z-index: 999;
            }

                #sidebar.active {
                    margin-left: -260px;
                }

            .sidebar-header {
                padding: 1.5rem;
                background: #0f172a;
                font-weight: 700;
                letter-spacing: 1px;
            }

            .nav-pills .nav-link {
                color: #94a3b8;
                padding: 0.8rem 1.5rem;
                border-radius: 0;
                font-size: 0.9rem;
                border-left: 4px solid transparent;
            }

                .nav-pills .nav-link:hover {
                    background: var(--sidebar-hover);
                    color: #fff;
                }

                .nav-pills .nav-link.active {
                    background: var(--sidebar-hover);
                    color: #fff;
                    border-left: 4px solid var(--primary-color);
                }

            /* Ana İçerik */
            #content {
                width: 100%;
                min-height: 100vh;
            }

            .top-navbar {
                background: #fff;
                padding: 0.75rem 1.5rem;
                border-bottom: 1px solid #e2e8f0;
            }

            /* Bildirim Paneli Stilleri */
            #notification-wrapper {
                position: fixed;
                bottom: 30px;
                right: 30px;
                z-index: 1060;
            }

            #notifyBtn {
                width: 55px;
                height: 55px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            }

                #notifyBtn:hover {
                    transform: scale(1.1) rotate(10deg);
                }

            #notifyPanel {
                width: 320px;
                position: absolute;
                bottom: 70px;
                right: 0;
                display: none;
                border: none;
                box-shadow: 0 10px 25px rgba(0,0,0,0.15);
            }

            .notify-item {
                padding: 12px 16px;
                border-bottom: 1px solid #f1f5f9;
                transition: background 0.2s;
            }

                .notify-item:hover {
                    background-color: #f8fafc;
                }

            .notify-icon-circle {
                width: 35px;
                height: 35px;
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
            }

            .footer {
                padding: 1rem 1.5rem;
                background: #fff;
                border-top: 1px solid #e2e8f0;
                font-size: 0.85rem;
            }
    </style>
</head>
<body>

    <div class="d-flex align-items-stretch">
        <nav id="sidebar" class="shadow">
            <div class="sidebar-header text-center">
                <span class="text-primary"><i class="bi bi-cpu-fill"></i></span> TEKNİK<span class="text-primary">CRM</span>
            </div>

            <div class="p-3 small text-uppercase text-muted fw-bold" style="font-size: 0.7rem;">Ana Menü</div>
            <ul class="nav nav-pills flex-column mb-auto">
                <li class="nav-item">
                    <a href="/Home/Index" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")"><i class="bi bi-grid-1x2-fill"></i>  Dashboard</a>
                </li>
                <li><a href="/Musteri/Index" class="nav-link"><i class="bi bi-people-fill"></i>  Müşteriler</a></li>
                <li><a href="/Cihaz/Index" class="nav-link"><i class="bi bi-pc-display"></i>  Cihazlar</a></li>
                <li><a href="/ServisKayit/Index" class="nav-link"><i class="bi bi-tools"></i>  İş Emirleri</a></li>
                <li><a href="/Randevu/Index" class="nav-link"><i class="bi bi-calendar-event"></i>  Randevu & Takvim</a></li>
                <li><a href="/Home/Kullanicilar" class="nav-link"><i class="bi bi-person-badge-fill"></i>  Teknisyen Takibi</a></li>
                <li><a href="/Finans/KasaHareketi" class="nav-link"><i class="bi bi-wallet2"></i>  Tahsilat & Finans</a></li>
                <li><a href="/Bildirim" class="nav-link"><i class="bi bi-bell-fill"></i>  Bildirimler</a></li>
                <li><a href="/Rapor" class="nav-link"><i class="bi bi-bar-chart-line-fill"></i>  Raporlama</a></li>
                <li><a href="/Admin/Roller" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Roller" ? "active" : "")"><i class="bi bi-shield-lock-fill"></i>  Rol & Yetki</a></li>
               
              
            </ul>
        </nav>

        <div id="content" class="d-flex flex-column">
            <nav class="navbar navbar-expand-lg top-navbar">
                <div class="container-fluid p-0">
                    <button type="button" id="sidebarCollapse" class="btn btn-light border">
                        <i class="bi bi-text-indent-left"></i>
                    </button>

                    <div class="ms-auto d-flex align-items-center">
                        <div class="dropdown">
                            @{
                                var fullName = Context.Session.GetString("FullName") ?? "Kullanıcı";
                            }
                            <a href="#" class="d-flex align-items-center text-dark text-decoration-none dropdown-toggle" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                                <img src="https://ui-avatars.com/api/?name=@fullName&background=0D8ABC&color=fff&bold=true" alt="" width="32" height="32" class="rounded-circle me-2 border shadow-sm">
                                <strong class="d-none d-sm-block">@fullName</strong>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3 py-2 rounded-3 animate slideIn">
                                <li class="px-3 py-2 border-bottom mb-2">
                                    <div class="small text-muted">Hoş geldiniz,</div>
                                    <div class="fw-bold">@fullName</div>
                                </li>
                                <li><a class="dropdown-item py-2" href="/Home/Profil"><i class="bi bi-person-circle me-2 text-primary"></i>Profilim</a></li>
                                <li><a class="dropdown-item py-2" href="/Ayarlar"><i class="bi bi-gear me-2 text-secondary"></i>Ayarlar</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item py-2 text-danger fw-bold" href="/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i>Güvenli Çıkış</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>

            <div class="container-fluid p-4 flex-grow-1">
                @RenderBody()
            </div>

            <footer class="footer d-flex justify-content-between">
                <div><strong>Teknik CRM</strong> &copy; 2026</div>
                <div class="text-muted small">Tasarım & Yazılım: <strong>Beyza Akbulut</strong></div>
            </footer>
        </div>
    </div>

    <div id="notification-wrapper">
        <button id="notifyBtn" class="btn btn-primary shadow-lg border-0 position-relative">
            <i class="bi bi-bell-fill fs-4"></i>
            <span id="notifyCount" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
        </button>

        <div id="notifyPanel" class="card rounded-4 overflow-hidden shadow-lg animate slideIn">
            <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
                <span class="fw-bold text-dark small"><i class="bi bi-lightning-charge-fill text-warning me-1"></i> Bildirimler</span>
                <span id="notifyStatus" class="badge bg-light text-muted" style="font-size: 9px;">Güncel</span>
            </div>
            <div class="card-body p-0" id="notifyContainer" style="max-height: 350px; overflow-y: auto;">
            </div>
            <div class="card-footer bg-light text-center py-2 border-0">
                <a href="/Bildirim" class="text-decoration-none small fw-bold">Tümünü Gör</a>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        $(document).ready(function () {
        // Sidebar Toggle
        $('#sidebarCollapse').on('click', function () {
        $('#sidebar').toggleClass('active');
        $(this).find('i').toggleClass('bi-text-indent-left bi-text-indent-right');
        });

        // Bildirim Paneli Toggle
        $('#notifyBtn').click(function(e) {
        e.stopPropagation();
        $('#notifyPanel').fadeToggle(200);
        });

        $(document).click(function() {
        $('#notifyPanel').fadeOut(200);
        });

        $('#notifyPanel').click(function(e) {
        e.stopPropagation();
        });

        // Bildirimleri Kontrol Et (Her 1 dakikada bir)
        checkNotifications();
        setInterval(checkNotifications, 60000);
        });

        function checkNotifications() {
        $.get('/Home/GetNotifications', function(res) {
        if(res.count > 0) {
        $('#notifyCount').text(res.count).removeClass('d-none');
        let html = "";
        res.items.forEach(item => {
        let icon = item.tip === 'payment' ? 'bi-cash-stack text-success' : 'bi-tools text-warning';
        let bg = item.tip === 'payment' ? 'rgba(25, 135, 84, 0.1)' : 'rgba(255, 193, 7, 0.1)';

        html += `
        <div class="notify-item d-flex align-items-center">
        <div class="notify-icon-circle me-3" style="background: ${bg}">
        <i class="bi ${icon} fs-5"></i>
        </div>
        <div class="flex-grow-1">
        <div class="d-flex justify-content-between">
        <span class="fw-bold small" style="font-size:0.75rem">${item.baslik}</span>
        <span class="text-muted" style="font-size:0.65rem">${item.tarih}</span>
        </div>
        <div class="text-muted truncate" style="font-size:0.7rem">${item.detay}</div>
        </div>
        </div>`;
        });
        $('#notifyContainer').html(html);
        } else {
        $('#notifyCount').addClass('d-none');
        $('#notifyContainer').html('<div class="p-4 text-center text-muted small"><i class="bi bi-bell-slash d-block fs-2 mb-2"></i>Yeni bildirim yok.</div>');
        }
        });
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>