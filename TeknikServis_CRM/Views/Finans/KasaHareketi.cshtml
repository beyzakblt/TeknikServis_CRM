@{
    ViewData["Title"] = "Finans & Bakiye Yönetimi";
}

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

<style>
    :root {
        --primary: #4e73df;
        --success: #1cc88a;
        --info: #36b9cc;
        --warning: #f6c23e;
        --danger: #e74a3b;
        --light-bg: #f8f9fc;
    }

    body {
        background-color: var(--light-bg);
        font-family: 'Inter', sans-serif;
    }

    .card-main {
        border: none;
        border-radius: 25px;
        box-shadow: 0 10px 30px rgba(58,59,69,0.08);
        background: #fff;
    }

    .stat-card-pro {
        background: #fff;
        border-radius: 20px;
        padding: 24px;
        border-left: 5px solid var(--primary);
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        transition: 0.3s;
    }

        .stat-card-pro:hover {
            transform: translateY(-5px);
        }

    .chart-container {
        position: relative;
        height: 320px;
        width: 100%;
    }

    .table-pro thead th {
        background-color: #f8fafc;
        text-transform: uppercase;
        font-size: 0.7rem;
        color: #858796;
        padding: 18px 20px;
        font-weight: 800;
        border: none;
    }

    .table-pro tbody td {
        padding: 15px 20px;
        border-bottom: 1px solid #eff2f7;
    }
</style>

<div class="container-fluid mt-4 px-md-5">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 class="h3 mb-1 text-gray-800 fw-bold"><i class="fas fa-wallet text-primary me-2"></i>Kasa & Bakiye Takibi</h2>
            <p class="text-muted small fw-bold">Gelir/Gider Dengesi ve Net Bakiye Yönetimi</p>
        </div>
        <div class="col-md-6 text-md-end d-flex justify-content-end gap-2">
            <button class="btn btn-danger rounded-pill px-4 shadow-sm fw-bold" onclick="yeniIslemModal('Gider')">
                <i class="fas fa-minus-circle me-1"></i> Gider Ekle
            </button>
            <button class="btn btn-success rounded-pill px-4 shadow-sm fw-bold" onclick="yeniIslemModal('Gelir')">
                <i class="fas fa-plus-circle me-1"></i> Gelir / Bakiye Ekle
            </button>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-xl-8">
            <div class="card card-main overflow-hidden border-0">
                <div class="card-body p-4">
                    <div id="financeCarousel" class="carousel slide" data-bs-ride="carousel">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <h6 class="text-center fw-bold text-primary mb-3">Finansal Dağılım Özeti</h6>
                                <div class="chart-container"><canvas id="chartIslem"></canvas></div>
                            </div>
                            <div class="carousel-item">
                                <h6 class="text-center fw-bold text-success mb-3">Ödeme Kanalları</h6>
                                <div class="chart-container"><canvas id="chartYontem"></canvas></div>
                            </div>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#financeCarousel" data-bs-slide="prev"><span class="carousel-control-prev-icon" style="filter:invert(1)"></span></button>
                        <button class="carousel-control-next" type="button" data-bs-target="#financeCarousel" data-bs-slide="next"><span class="carousel-control-next-icon" style="filter:invert(1)"></span></button>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="d-flex flex-column gap-3 h-100">
                <div class="stat-card-pro flex-fill" style="border-left-color: var(--success);">
                    <div class="text-xs fw-bold text-success text-uppercase mb-1 small">Net Kasa Bakiyesi</div>
                    <div class="h3 mb-0 fw-bold text-gray-800">₺<span id="totalIncome">0,00</span></div>
                </div>
                <div class="stat-card-pro flex-fill" style="border-left-color: var(--danger);">
                    <div class="text-xs fw-bold text-danger text-uppercase mb-1 small">Toplam Gider</div>
                    <div class="h3 mb-0 fw-bold text-gray-800">₺<span id="totalExpense">0,00</span></div>
                </div>
                <a href="/Finans/ExcelIndir" class="btn btn-white border rounded-4 p-3 fw-bold shadow-sm text-dark">
                    <i class="fas fa-file-excel text-success me-2"></i> Excel Dökümü Al
                </a>
            </div>
        </div>
    </div>

    <div class="card card-main border-0">
        <div class="card-header bg-white py-3 border-0 d-flex justify-content-between align-items-center px-4">
            <h6 class="m-0 fw-bold text-primary">Kasa Hareket Dökümü</h6>
            <input type="text" id="financeSearch" class="form-control form-control-sm rounded-pill bg-light border-0 px-3" style="width:220px" placeholder="Ara...">
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="tblKasa" class="table table-hover table-pro align-middle w-100 m-0 border-0">
                    <thead>
                        <tr>
                            <th>Tarih</th>
                            <th>Açıklama / Cari</th>
                            <th>Yöntem</th>
                            <th>Tür</th>
                            <th class="text-end">Tutar</th>
                            <th class="text-center">İşlem</th>
                        </tr>
                    </thead>
                    <tbody class="small"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlTahsilat" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content card-main p-3">
            <form id="frmTahsilat">
                <div class="modal-header border-0"><h5 class="fw-bold" id="modalTitle">İşlem Girişi</h5></div>
                <div class="modal-body">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="small fw-bold">İlgili Cari / Müşteri (Opsiyonel)</label>
                            <select name="MusteriId" id="ddlMusteri" class="form-select rounded-3 shadow-sm">
                                <option value="">-- Genel Cari --</option>
                                @foreach (var m in ViewBag.Musteriler)
                                {
                                    <option value="@m.Id">@m.AdSoyad</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="small fw-bold">Miktar (₺)</label>
                            <input type="number" name="Tutar" id="txtTutar" class="form-control rounded-3 fw-bold shadow-sm" step="0.01" required>
                        </div>
                        <div class="col-md-6">
                            <label class="small fw-bold">Ödeme Kanalı</label>
                            <select name="OdemeYontemi" class="form-select rounded-3 shadow-sm">
                                <option value="Nakit">Nakit</option>
                                <option value="Kredi Kartı">Kredi Kartı</option>
                                <option value="Havale/EFT">Havale/EFT</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="small fw-bold">İşlem Kategorisi / Notu</label>
                            <select name="IslemTipi" id="ddlIslemTipi" class="form-select rounded-3 shadow-sm" required>
                                <optgroup label="GELİR / BAKİYE" id="optGelir">
                                    <option value="Gelir">Servis Tahsilatı</option>
                                    <option value="Bakiye">Sermaye Girişi / Bakiye</option>
                                </optgroup>
                                <optgroup label="GİDERLER" id="optGider">
                                    <option value="Gider">Dükkan Kirası / Fatura</option>
                                    <option value="Gider">Yedek Parça Alımı</option>
                                    <option value="Gider">Personel / Maaş</option>
                                    <option value="Gider">Yemek / Yol / Diğer</option>
                                </optgroup>
                            </select>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="submit" id="btnSubmit" class="btn btn-primary w-100 rounded-pill py-2 fw-bold shadow">Kasaya İşle</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        let table;
        let charts = {};

        $(document).ready(function () {
        table = $('#tblKasa').DataTable({
        "ajax": { "url": "/Finans/GetKasaListesi", "dataSrc": "" },
        "columns": [
        { "data": "tarih", "render": d => `<span class="text-muted fw-bold">${d}</span>` },
        { "data": "musteriAd", "defaultContent": "Genel Kasa İşlemi" },
        { "data": "odemeYontemi", "render": d => `<span class="badge bg-light text-primary border px-3 rounded-pill">${d}</span>` },
        {
        "data": "islemTipi",
        "render": (d, t, row) => {
        let isGider = row.tutar < 0;
        return `<span class="badge ${isGider ? 'bg-soft-danger text-danger' : 'bg-soft-success text-success'} rounded-pill">${d || 'İşlem'}</span>`;
        }
        },
        {
        "data": "tutar",
        "className": "text-end",
        "render": d => {
        let val = parseFloat(d);
        let color = val < 0 ? 'text-danger' : 'text-success';
        let sign = val < 0 ? '' : '+';
        return `<span class="fw-bold ${color}">${sign}${val.toLocaleString('tr-TR', { minimumFractionDigits: 2 })} ₺</span>`;
        }
        },
        { "data": "id", "className": "text-center", "render": d => `<button class="btn btn-sm text-danger" onclick="islemSil(event, ${d})"><i class="fas fa-trash"></i></button>` }
        ],
        "order": [[0, "desc"]],
        "initComplete": function (s, json) { calculateTotals(json); initCharts(); },
        "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json" }
        });

        $('#financeSearch').keyup(function () { table.search($(this).val()).draw(); });

        $('#frmTahsilat').submit(function (e) {
        e.preventDefault();
        $.post('/Finans/OdemeAl', $(this).serialize(), r => {
        if (r.success) {
        $('#mdlTahsilat').modal('hide');
        table.ajax.reload(j => { calculateTotals(j); initCharts(); });
        Swal.fire('Başarılı', 'İşlem kasaya yansıdı.', 'success');
        }
        });
        });
        });

        function calculateTotals(data) {
        // Net Bakiye Hesabı
        let net = data.reduce((a, b) => a + (parseFloat(b.tutar) || 0), 0);
        $('#totalIncome').text(net.toLocaleString('tr-TR', { minimumFractionDigits: 2 }));

        // Sadece Giderlerin Toplamı
        let expense = data.filter(x => x.tutar < 0).reduce((a, b) => a + (parseFloat(b.tutar) || 0), 0);
        $('#totalExpense').text(Math.abs(expense).toLocaleString('tr-TR', { minimumFractionDigits: 2 }));
        }

        function yeniIslemModal(tip) {
        $('#frmTahsilat')[0].reset();
        const isGider = tip === 'Gider';

        $('#modalTitle').text(isGider ? 'Yeni Gider Girişi' : 'Yeni Gelir / Bakiye Girişi');
        $('#modalTitle').removeClass('text-success text-danger').addClass(isGider ? 'text-danger' : 'text-success');
        $('#btnSubmit').removeClass('btn-primary btn-danger btn-success').addClass(isGider ? 'btn-danger' : 'btn-success');

        // Kategorileri kısıtla
        if (isGider) {
        $('#optGelir').hide(); $('#optGider').show();
        $('#ddlIslemTipi').val('Gider');
        } else {
        $('#optGelir').show(); $('#optGider').hide();
        $('#ddlIslemTipi').val('Gelir');
        }

        $('#mdlTahsilat').modal('show');
        }

        function initCharts() {
        $.get('/Finans/GetFinansOzetGrafik', function (res) {
        if (charts.islem) charts.islem.destroy();
        charts.islem = new Chart(document.getElementById('chartIslem'), {
        type: 'bar',
        data: {
        labels: res.islemler.map(x => x.etiket),
        datasets: [{
        label: 'Hacim (₺)',
        data: res.islemler.map(x => x.toplam),
        backgroundColor: '#4e73df'
        }]
        },
        options: { maintainAspectRatio: false }
        });

        if (charts.yontem) charts.yontem.destroy();
        charts.yontem = new Chart(document.getElementById('chartYontem'), {
        type: 'doughnut',
        data: {
        labels: res.yontemler.map(x => x.etiket),
        datasets: [{
        data: res.yontemler.map(x => x.toplam),
        backgroundColor: ['#4e73df', '#1cc88a', '#36b9cc']
        }]
        },
        options: { maintainAspectRatio: false, cutout: '70%' }
        });
        });
        }

        function islemSil(e, id) {
        e.stopPropagation();
        Swal.fire({
        title: 'Emin misiniz?',
        text: "Bu finansal hareketi silmek kasayı etkileyecektir!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Evet, Sil'
        }).then(r => {
        if (r.isConfirmed) $.post('/Finans/KasaSil/' + id, () => {
        table.ajax.reload(j => { calculateTotals(j); initCharts(); });
        });
        });
        }
    </script>
}