@{
    ViewData["Title"] = "Cihaz Yönetimi";
}

<div class="container-fluid mt-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 class="h3 mb-1 text-gray-800 fw-bold">
                <i class="fas fa-microchip text-primary me-2"></i>Cihaz Envanteri
            </h2>
            <p class="text-muted mb-0 small text-uppercase fw-bold ls-1">Teknik Servis Varlık Takibi</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <button class="btn btn-primary shadow-sm rounded-pill px-4 fw-bold" onclick="yeniCihazModal()">
                <i class="fas fa-plus-circle me-1"></i> Yeni Cihaz Kaydı
            </button>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-start border-primary border-4 shadow-sm h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1 small">Toplam Cihaz</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800" id="totalDeviceCount">0</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-boxes fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-xl-9 col-md-12 mb-4">
            <div class="card shadow-sm border-0 h-100 py-1">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted">Müşteri Filtresi</label>
                            <input type="text" id="filterMusteri" class="form-control form-control-sm rounded-pill" placeholder="Müşteri adıyla ara...">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-muted">Cihaz Tipi</label>
                            <select id="filterCihazTip" class="form-select form-select-sm rounded-pill">
                                <option value="">Tümü</option>
                                @if (ViewBag.CihazTipleri != null)
                                {
                                    foreach (var item in (SelectList)ViewBag.CihazTipleri)
                                    {
                                        <option value="@item.Text">@item.Text</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-muted">Marka / Model</label>
                            <input type="text" id="filterMarka" class="form-control form-control-sm rounded-pill" placeholder="Marka veya model...">
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button class="btn btn-outline-secondary btn-sm w-100 rounded-pill" onclick="filtreleriTemizle()">
                                <i class="fas fa-undo me-1"></i> Temizle
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-dark">Envanter Listesi</h6>
            <button class="btn btn-sm btn-light border text-primary rounded-circle" onclick="table.ajax.reload()">
                <i class="fas fa-sync-alt"></i>
            </button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="tblCihazlar" class="table table-hover align-middle w-100">
                    <thead>
                        <tr class="text-secondary bg-light">
                            <th>MÜŞTERİ</th>
                            <th>CİHAZ TİPİ</th>
                            <th>MARKA / MODEL</th>
                            <th>SERİ NO</th>
                            <th class="text-center">İŞLEMLER</th>
                        </tr>
                    </thead>
                    <tbody class="small"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlCihaz" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white border-0 py-3">
                <h5 class="modal-title fw-bold" id="modalBaslik">
                    <i class="fas fa-edit me-2"></i>Cihaz Bilgileri
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="frmCihaz">
                <div class="modal-body p-4">
                    <input type="hidden" name="Id" id="txtId" value="0" />

                    <div class="mb-3">
                        <label class="form-label fw-bold text-dark small">Müşteri Seçimi</label>
                        <select name="MusteriId" id="ddlMusteri" class="form-select" asp-items="ViewBag.Musteriler" required>
                            <option value="">Seçiniz...</option>
                        </select>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark small">Cihaz Tipi</label>
                            <select name="CihazTipId" id="ddlCihazTip" class="form-select" asp-items="ViewBag.CihazTipleri" required>
                                <option value="">Seçiniz...</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark small">Marka</label>
                            <input type="text" name="Marka" id="txtMarka" class="form-control" placeholder="Örn: Daikin" required />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark small">Model</label>
                            <input type="text" name="Model" id="txtModel" class="form-control" placeholder="Örn: Sensira" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-dark small">Seri Numarası</label>
                            <input type="text" name="SeriNo" id="txtSeriNo" class="form-control" placeholder="S/N: 123..." />
                        </div>
                    </div>

                    <div class="mb-0">
                        <label class="form-label fw-bold text-dark small">Garanti Bitiş Tarihi</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white"><i class="fas fa-calendar-alt text-muted"></i></span>
                            <input type="date" name="GarantiBitisTarihi" id="txtGarantiTarihi" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 py-3">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                        <i class="fas fa-save me-1"></i> Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        let table;

        $(document).ready(function () {
        table = $('#tblCihazlar').DataTable({
        "ajax": {
        "url": "/Cihaz/GetCihazListesi",
        "dataSrc": ""
        },
        "dom": '<"top"rt><"bottom"ip><"clear">', // Varsayılan arama kutusunu gizle, biz kendimizinkini yaptık
        "initComplete": function(settings, json) {
        $('#totalDeviceCount').text(json.length);
        },
        "columns": [
        {
        "data": "musteriAd",
        "render": d => `<div class="fw-bold text-dark">${d}</div>`
        },
        {
        "data": "cihazTipi",
        "render": d => `<span class="badge rounded-pill bg-soft-info text-info border border-info px-3"> ${d}</span>`
        },
        {
        "data": null,
        "render": d => `<div>${d.marka}</div><small class="text-muted">${d.model || '-'}</small>`
        },
        {
        "data": "seriNo",
        "render": d => `<code class="text-dark fw-bold">${d || '-'}</code>`
        },
        {
        "data": "id",
        "orderable": false,
        "className": "text-center",
        "render": d => `
        <div class="d-flex justify-content-center gap-2">
        <button class="btn btn-sm btn-outline-warning rounded-circle action-btn" onclick="cihazDuzenle(${d})">
        <i class="fas fa-pencil-alt"></i>
        </button>
        <button class="btn btn-sm btn-outline-danger rounded-circle action-btn" onclick="cihazSil(${d})">
        <i class="fas fa-trash-alt"></i>
        </button>
        </div>`
        }
        ],
        "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json" }
        });

        // Özel Filtreleme Tetikleyicileri
        $('#filterMusteri').on('keyup', function() { table.column(0).search(this.value).draw(); });
        $('#filterCihazTip').on('change', function() { table.column(1).search(this.value).draw(); });
        $('#filterMarka').on('keyup', function() { table.column(2).search(this.value).draw(); });
        });

        function filtreleriTemizle() {
        $('#filterMusteri, #filterMarka').val('');
        $('#filterCihazTip').val('');
        table.columns().search('').draw();
        }

        // Form Gönderimi (AJAX)
        $('#frmCihaz').submit(function (e) {
        e.preventDefault();
        $.post('/Cihaz/Kaydet', $(this).serialize(), function (res) {
        if (res.success) {
        $('#mdlCihaz').modal('hide');
        table.ajax.reload();
        Swal.fire({ icon: 'success', title: 'Başarılı!', text: res.message, timer: 1500, showConfirmButton: false });
        } else {
        Swal.fire('Hata!', res.message, 'error');
        }
        });
        });

        // Diğer Fonksiyonlar (Duzenle/Sil/Yeni)
        function yeniCihazModal() {
        $('#frmCihaz')[0].reset();
        $('#txtId').val(0);
        $('#modalBaslik').html('<i class="fas fa-plus-circle me-2"></i>Yeni Cihaz Kaydı');
        $('#mdlCihaz').modal('show');
        }

        function cihazDuzenle(id) {
        $.get('/Cihaz/GetCihaz/' + id, function (res) {
        if (res) {
        $('#txtId').val(res.id);
        $('#ddlMusteri').val(res.musteriId);
        $('#ddlCihazTip').val(res.cihazTipId);
        $('#txtMarka').val(res.marka);
        $('#txtModel').val(res.model);
        $('#txtSeriNo').val(res.seriNo);
        if(res.garantiBitisTarihi) $('#txtGarantiTarihi').val(res.garantiBitisTarihi.split('T')[0]);
        $('#modalBaslik').html('<i class="fas fa-pencil-alt me-2"></i>Cihaz Düzenle');
        $('#mdlCihaz').modal('show');
        }
        });
        }

        function cihazSil(id) {
        Swal.fire({
        title: 'Silmek istediğinize emin misiniz?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Evet, Sil',
        cancelButtonText: 'Hayır'
        }).then((result) => {
        if (result.isConfirmed) {
        $.post('/Cihaz/Sil/' + id, function (res) {
        if (res.success) {
        table.ajax.reload();
        Swal.fire('Silindi!', '', 'success');
        }
        });
        }
        });
        }
    </script>

    <style>
        body {
        background-color: #f8f9fc;
        }

        .ls-1 {
        letter-spacing: 1px;
        }

        .bg-soft-info {
        background-color: rgba(54, 185, 204, 0.1);
        }

        .action-btn {
        width: 34px;
        height: 34px;
        transition: all 0.2s;
        }

        .action-btn:hover {
        transform: scale(1.1);
        background-color: #4e73df;
        color: white !important;
        }

        .table thead th {
        font-size: 0.7rem;
        letter-spacing: 0.5px;
        border: none;
        }

        .form-select-sm, .form-control-sm {
        border: 1px solid #eaecf4;
        }

        .form-select:focus, .form-control:focus {
        border-color: #4e73df;
        box-shadow: none;
        }
    </style>
}