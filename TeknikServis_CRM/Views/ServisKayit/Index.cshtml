@{
    ViewData["Title"] = "Servis & İş Emri Paneli";
}

<div class="container-fluid mt-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 class="h3 mb-1 text-gray-800 font-weight-bold">
                <i class="fas fa-tools text-primary me-2"></i>Servis & İş Emirleri
            </h2>
            <p class="text-muted mb-0 small fw-bold text-uppercase">Teknik Operasyon ve Ödeme Takibi</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <button class="btn btn-warning shadow-sm rounded-pill px-4 py-2 me-2 text-dark fw-bold" onclick="yaklasanOdemeleriGoster()">
                <i class="fas fa-clock me-1"></i> Yaklaşan Ödemeler
            </button>
            <button class="btn btn-primary shadow-sm rounded-pill px-4 py-2" onclick="yeniServisModal()">
                <i class="fas fa-plus-circle me-1"></i> Yeni Servis Kaydı
            </button>
        </div>
    </div>

    <div class="row mb-3 g-2">
        <div class="col-md-10">
            <div class="btn-group shadow-sm border rounded-pill bg-white p-1" role="group">
                <button type="button" class="btn btn-sm rounded-pill px-3 active filter-btn" data-filter="">Tümü</button>
                <button type="button" class="btn btn-sm rounded-pill px-3 filter-btn" data-filter="Yeni Atandı">Yeni Atandı</button>
                <button type="button" class="btn btn-sm rounded-pill px-3 filter-btn" data-filter="İşlemde">İşlemde</button>
                <button type="button" class="btn btn-sm rounded-pill px-3 filter-btn" data-filter="Parça Bekliyor">Parça Bekliyor</button>
                <button type="button" class="btn btn-sm rounded-pill px-3 filter-btn" data-filter="Tamamlandı">Tamamlandı</button>
            </div>
        </div>
        <div class="col-md-2">
            <select id="payFilter" class="form-select form-select-sm rounded-pill shadow-sm border-0 bg-white">
                <option value="">Tüm Ödemeler</option>
                <option value="Ödendi">Ödendi</option>
                <option value="Bekliyor">Bekliyor</option>
            </select>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden text-dark">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table id="tblServisler" class="table table-hover align-middle w-100 border-0">
                    <thead class="bg-light">
                        <tr class="text-secondary small fw-bold">
                            <th>Servis No</th>
                            <th>Müşteri / Cihaz</th>
                            <th>Ücret / Ödeme</th>
                            <th>Ödeme Vadesi</th>
                            <th>Durum</th>
                            <th class="text-center" style="width:140px">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody class="small"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlMusteriOzet" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered text-dark">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-dark text-white py-2 border-0">
                <h6 class="modal-title fw-bold small"><i class="fas fa-user-circle me-2"></i>Müşteri Bilgi Özeti</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <div class="avatar-circle bg-primary text-white mx-auto mb-2 shadow" style="width:60px; height:60px; line-height:60px; border-radius:50%; font-size:24px;">
                    <i class="fas fa-user"></i>
                </div>
                <h5 id="mo_AdSoyad" class="fw-bold mb-1">...</h5>
                <p id="mo_Firma" class="text-muted small">...</p>
                <hr />
                <div class="text-start p-3 bg-light rounded-3">
                    <div class="mb-2 d-flex justify-content-between border-bottom pb-2">
                        <span class="text-muted small fw-bold"><i class="fas fa-phone me-2 text-primary"></i>Telefon:</span>
                        <b id="mo_Tel" class="small">...</b>
                    </div>
                    <div class="mb-2 d-flex justify-content-between border-bottom pb-2">
                        <span class="text-muted small fw-bold"><i class="fas fa-envelope me-2 text-primary"></i>E-Posta:</span>
                        <b id="mo_Mail" class="small">...</b>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small fw-bold"><i class="fas fa-wallet me-2 text-success"></i>Toplam Tahsilat:</span>
                        <b id="mo_Ciro" class="small text-success">...</b>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlServis" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered text-dark">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white border-0 py-2">
                <h5 class="modal-title fw-bold small" id="modalBaslik"><i class="fas fa-file-invoice me-2"></i>Servis & İş Emri Detayı</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <ul class="nav nav-tabs nav-justified bg-light" id="servisTabs" role="tablist">
                <li class="nav-item">
                    <button class="nav-link active small fw-bold text-dark" id="genel-tab" data-bs-toggle="tab" data-bs-target="#genel" type="button">
                        <i class="fas fa-info-circle me-1"></i> GENEL BİLGİLER
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link small fw-bold text-danger" id="isemri-tab" data-bs-toggle="tab" data-bs-target="#isemri" type="button">
                        <i class="fas fa-user-cog me-1"></i> TEKNİK İŞ EMRİ & NOTLAR
                    </button>
                </li>
            </ul>

            <form id="frmServis">
                <div class="modal-body p-4">
                    <div class="tab-content" id="myTabContent">
                        <div class="tab-pane fade show active" id="genel" role="tabpanel">
                            <input type="hidden" name="Id" id="txtId" value="0" />
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">Müşteri</label>
                                    <select name="MusteriId" id="ddlMusteri" class="form-select" required onchange="cihazlariGetir(this.value)">
                                        <option value="">-- Müşteri Seçiniz --</option>
                                        @foreach (var m in ViewBag.Musteriler)
                                        {
                                            <option value="@m.Id">@m.AdSoyad</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-bold small">Cihaz</label>
                                    <select name="MusteriCihazId" id="ddlCihaz" class="form-select">
                                        <option value="">-- Cihaz Seçiniz --</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small">Servis Durumu</label>
                                    <select name="ServisDurumId" id="ddlDurum" class="form-select" required>
                                        @foreach (var d in ViewBag.Durumlar)
                                        {
                                            <option value="@d.Id">@d.DurumAdi</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small text-primary">Ücret</label>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text">₺</span>
                                        <input type="number" name="Ucret" id="txtUcret" class="form-control" step="0.01" />
                                        <select name="OdemeDurumu" id="txtOdemeDurumu" class="form-select">
                                            <option value="Bekliyor">Bekliyor</option>
                                            <option value="Ödendi">Ödendi</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label fw-bold small text-danger">Ödeme Vadesi</label>
                                    <input type="date" name="VadeTarihi" id="txtVadeTarihi" class="form-control form-control-sm border-danger" />
                                </div>
                                <div class="col-md-12">
                                    <label class="form-label fw-bold small">Müşteri Şikayeti (Arıza Açıklaması)</label>
                                    <textarea name="ArizaAciklamasi" id="txtAriza" class="form-control" rows="2"></textarea>
                                </div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="isemri" role="tabpanel">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="small fw-bold text-primary">Sorumlu Teknisyen</label>
                                    <select name="TeknisyenKullaniciId" id="ddlTeknisyen" class="form-select border-primary">
                                        <option value="">-- Teknisyen Atanmadı --</option>
                                        @if (ViewBag.Teknisyenler != null)
                                        {
                                            foreach (var t in ViewBag.Teknisyenler)
                                            {
                                                <option value="@t.Id">@t.AdSoyad</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="small fw-bold text-primary">İş Emri Durumu</label>
                                    <select id="txtIsEmriDurum_Display" class="form-select border-primary">
                                        <option value="Yeni Atandı">Yeni Atandı</option>
                                        <option value="İşlemde">İşlemde</option>
                                        <option value="Parça Bekliyor">Parça Bekliyor</option>
                                        <option value="Tamamlandı">Tamamlandı</option>
                                    </select>
                                </div>

                                <div class="col-md-12 mt-3">
                                    <label class="small fw-bold text-danger"><i class="fas fa-plus me-1"></i> Yeni Teknik İşlem Notu Ekle</label>
                                    <div class="input-group">
                                        <textarea id="txtYeniNotGiris" class="form-control border-danger shadow-none" rows="2" placeholder="Yapılan işlemi veya parça bilgisini yazın..."></textarea>
                                        <button type="button" class="btn btn-danger px-3" onclick="teknikNotKaydet()"><i class="fas fa-save"></i></button>
                                    </div>
                                </div>

                                <div class="col-md-12">
                                    <label class="small fw-bold text-muted mt-2">Teknik Çalışma Geçmişi</label>
                                    <div id="teknikNotListesi" class="bg-light p-3 rounded-3 border overflow-auto" style="max-height: 250px;">
                                        <div class="text-center text-muted small py-3">Henüz bir işlem notu girilmemiş.</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-light border-0 py-3">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Vazgeç</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">
                        <i class="fas fa-save me-1"></i> Servis Kaydını Güncelle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlYaklasanOdemeler" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered text-dark">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning py-2 text-dark border-0">
                <h6 class="modal-title fw-bold"><i class="fas fa-exclamation-circle me-2"></i>Vadesi Yaklaşan Ödemeler</h6>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div id="yaklasanListe" class="list-group list-group-flush"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        let table;

        $(document).ready(function () {
        // 1. DATATABLE YÜKLEME
        table = $('#tblServisler').DataTable({
        "ajax": { "url": "/ServisKayit/GetServisListesi", "dataSrc": "" },
        "columns": [
        { "data": "servisNo", "render": d => `<span class="fw-bold text-primary font-monospace">${d}</span>` },
        { "data": null, "render": d => `<div><a href="javascript:void(0)" onclick="musteriOzetGetir(${d.id})" class="fw-bold text-dark text-decoration-none border-bottom border-primary">${d.musteriAd}</a></div><small class="text-muted italic">${d.cihazBilgi}</small>` },
        { "data": null, "render": d => `<div><span class="fw-bold text-success">₺${d.ucret ? d.ucret.toLocaleString('tr-TR') : '0,00'}</span></div><small class="badge ${d.odemeDurumu == 'Ödendi' ? 'bg-success' : 'bg-danger'}">${d.odemeDurumu}</small>` },
        { "data": "odemeTarihi", "render": d => d ? `<span class="text-dark"><i class="far fa-calendar-alt me-1"></i>${new Date(d).toLocaleDateString('tr-TR')}</span>` : "-" },
        { "data": "durumAdi", "render": (d, t, r) => `<span class="badge shadow-sm px-3 py-2 text-white" style="background-color:${r.renkKodu || '#6c757d'}">${d}</span>` },
        {
        "data": "id", "className": "text-center", "render": d => `
        <div class="d-flex justify-content-center gap-1">
        <a href="/ServisKayit/ServisFisiIndir/${d}" target="_blank" class="btn btn-sm btn-outline-secondary rounded-circle action-btn" title="PDF"><i class="fas fa-file-pdf"></i></a>
        <button class="btn btn-sm btn-outline-info rounded-circle action-btn" onclick="teknikDetayAc(${d})" title="Teknik İş Emri"><i class="fas fa-user-cog"></i></button>
        <button class="btn btn-sm btn-outline-warning rounded-circle action-btn" onclick="servisDuzenle(${d})" title="Düzenle"><i class="fas fa-edit"></i></button>
        <button class="btn btn-sm btn-outline-danger rounded-circle action-btn" onclick="servisSil(${d})" title="Sil"><i class="fas fa-trash"></i></button>
        </div>`
        }
        ],
        "order": [[0, "desc"]],
        "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json" }
        });

        // 2. FORM KAYIT İŞLEMİ
        $('#frmServis').submit(function (e) {
        e.preventDefault();
        $.post('/ServisKayit/Kaydet', $(this).serialize(), function (res) {
        if (res.success) {
        $('#mdlServis').modal('hide');
        table.ajax.reload(null, false);
        Swal.fire("Başarılı", "Kayıt güncellendi.", "success");
        } else {
        Swal.fire("Hata", res.message, "error");
        }
        });
        });

        // 3. FİLTRELEME BUTONLARI
        $('.filter-btn').on('click', function () {
        $('.filter-btn').removeClass('btn-primary active text-white').addClass('btn-light');
        $(this).removeClass('btn-light').addClass('btn-primary active text-white');
        table.column(4).search($(this).data('filter') ? '^' + $(this).data('filter') + '$' : '', true, false).draw();
        });

        $('#payFilter').on('change', function () { table.column(2).search(this.value).draw(); });
        });

        // 4. ÇOKLU TEKNİK NOT İŞLEMLERİ (YapilanIslem sütununu kullanarak)
        function teknikNotKaydet() {
        let sId = $('#txtId').val();
        let not = $('#txtYeniNotGiris').val();
        if (sId == "0" || sId == "") { Swal.fire("Uyarı", "Önce genel bilgileri kaydedin.", "warning"); return; }
        if (!not.trim()) return;

        $.post('/ServisKayit/TeknikNotEkle', { servisId: sId, not: not }, function (res) {
        if (res.success) {
        $('#txtYeniNotGiris').val('');
        teknikNotlariGetir(sId);
        Swal.fire({ icon: 'success', title: 'Not Eklendi', timer: 1000, showConfirmButton: false });
        }
        });
        }

        function teknikNotlariGetir(servisId) {
        $.get('/ServisKayit/GetTeknikNotlar?servisId=' + servisId, function (res) {
        let div = $('#teknikNotListesi').empty();
        if (!res || res.length === 0) {
        div.append('<div class="text-center text-muted small py-3">Henüz işlem notu girilmemiş.</div>');
        } else {
        res.forEach(n => {
        div.append(`
        <div class="p-2 mb-2 border-start border-4 border-primary bg-white shadow-sm rounded-end">
        <div class="small text-dark">${n.icerik}</div>
        </div>
        `);
        });
        }
        });
        }

        // 5. MODAL VERİ ÇEKME FONKSİYONLARI
        function musteriOzetGetir(id) {
        $.get('/ServisKayit/GetServis/' + id, function (s) {
        $.get('/Musteri/GetFullDetay/' + s.musteriId, function (res) {
        if (res.success) {
        $('#mo_AdSoyad').text(res.musteri.adSoyad);
        $('#mo_Firma').text(res.musteri.firmaAdi || "Bireysel");
        $('#mo_Tel').text(res.musteri.telefon);
        $('#mo_Mail').text(res.musteri.eposta || "E-Posta Yok");
        $('#mo_Ciro').text(res.toplamCiro.toLocaleString('tr-TR') + " ₺");
        $('#mdlMusteriOzet').modal('show');
        }
        });
        });
        }

        function servisDuzenle(id) {
        $.get('/ServisKayit/GetServis/' + id, function (res) {
        $('#txtId').val(res.id);
        $('#ddlMusteri').val(res.musteriId);
        cihazlariGetir(res.musteriId, res.musteriCihazId);
        $('#ddlDurum').val(res.servisDurumId);
        $('#txtAriza').val(res.arizaAciklamasi);
        $('#txtUcret').val(res.ucret);
        $('#txtOdemeDurumu').val(res.odemeDurumu);
        if (res.kapanisTarihi) $('#txtVadeTarihi').val(res.kapanisTarihi.substring(0, 10));

        // İş emri detaylarını ata
        $('#ddlTeknisyen').val(res.teknisyenKullaniciId);

        teknikNotlariGetir(id);
        $('#modalBaslik').html('<i class="fas fa-edit me-2 text-warning"></i>Servis Düzenle');
        $('#mdlServis').modal('show');
        });
        }

        function cihazlariGetir(mId, selectedId = null) {
        if (!mId) return;
        $.get('/ServisKayit/GetMusteriCihazlari?musteriId=' + mId, function (res) {
        let ddl = $('#ddlCihaz').empty().append('<option value="">-- Cihaz Seçiniz --</option>');
        res.forEach(c => { ddl.append(`<option value="${c.id}">${c.ad}</option>`); });
        if (selectedId) ddl.val(selectedId);
        });
        }

        function yeniServisModal() {
        $('#frmServis')[0].reset();
        $('#txtId').val(0);
        $('#ddlCihaz').empty().append('<option value="">-- Önce Müşteri Seçiniz --</option>');
        $('#teknikNotListesi').empty().append('<div class="text-center text-muted small py-3">Yeni kayıtta henüz not bulunamaz.</div>');
        $('#modalBaslik').html('<i class="fas fa-plus-circle me-2 text-primary"></i>Yeni Servis Kaydı');
        $('#mdlServis').modal('show');
        }

        function teknikDetayAc(id) {
        servisDuzenle(id);
        setTimeout(() => { $('#isemri-tab').tab('show'); }, 400);
        }

        function servisSil(id) {
        Swal.fire({
        title: 'Emin misiniz?',
        text: "Bu kayıt kalıcı olarak silinecek!",
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        confirmButtonText: 'Evet, Sil!',
        cancelButtonText: 'Vazgeç'
        }).then((result) => {
        if (result.isConfirmed) {
        $.post('/ServisKayit/Sil/' + id, function () {
        table.ajax.reload(null, false);
        Swal.fire('Silindi!', 'Servis kaydı başarıyla silindi.', 'success');
        });
        }
        });
        }

        function yaklasanOdemeleriGoster() {
        $.get('/ServisKayit/GetYaklasanOdemeler', function (res) {
        let div = $('#yaklasanListe').empty();
        if (res.length == 0) {
        div.append('<div class="p-3 text-center text-muted small">Yaklaşan vadesi olan ödeme bulunamadı.</div>');
        } else {
        res.forEach(o => {
        div.append(`
        <div class="list-group-item">
        <div class="d-flex w-100 justify-content-between">
        <h6 class="mb-1 fw-bold text-dark">${o.musteriAd}</h6>
        <small class="text-danger fw-bold">${o.ucret} ₺</small>
        </div>
        <p class="mb-1 small text-muted">${o.servisNo} nolu servis kaydı.</p>
        <small class="text-secondary">Vade: ${o.tarih}</small>
        </div>`);
        });
        }
        $('#mdlYaklasanOdemeler').modal('show');
        });
        }
    </script>

    <style>
        .filter-btn {
        transition: all 0.2s ease;
        }

        .action-btn {
        transition: transform 0.2s;
        }

        .action-btn:hover {
        transform: scale(1.15);
        }

        .nav-tabs .nav-link.active {
        border-bottom: 3px solid #0d6efd;
        color: #0d6efd !important;
        font-weight: bold;
        }

        .font-monospace {
        font-family: 'Courier New', Courier, monospace;
        }

        .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.03);
        }

        .border-primary {
        border-bottom-style: dashed !important;
        border-bottom-width: 1px !important;
        }

        ::-webkit-scrollbar {
        width: 5px;
        }

        ::-webkit-scrollbar-thumb {
        background: #cbd5e1;
        border-radius: 10px;
        }

        .badge {
        letter-spacing: 0.3px;
        }
    </style>
}