@model TeknikServis_CRM.Models.Kullanicilar
@{
    ViewData["Title"] = "Detaylı Profil Bilgileri";
}

<div class="container py-4">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 text-center p-4">
                <img src="https://ui-avatars.com/api/?name=@Model.Ad+@Model.Soyad&background=3b82f6&color=fff&size=128" class="rounded-circle mx-auto shadow-sm mb-3" alt="Avatar">
                <h5 class="fw-bold mb-1">@Model.Ad @Model.Soyad</h5>
                <span class="badge bg-primary bg-opacity-10 text-primary px-3 mb-3">@ViewBag.RolAdi</span>
                
                <div class="list-group list-group-flush text-start small">
                    <div class="list-group-item d-flex justify-content-between border-0 px-0">
                        <span class="text-muted">Kullanıcı Adı:</span>
                        <span class="fw-bold">@Model.KullaniciAdi</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between border-0 px-0">
                        <span class="text-muted">Kayıt Tarihi:</span>
                        <span class="fw-bold">@Model.OlusturmaTarihi.ToString("dd.MM.yyyy")</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between border-0 px-0">
                        <span class="text-muted">Hesap Durumu:</span>
                        <span class="badge @(Model.Durum == "Aktif" ? "bg-success" : "bg-danger")">@Model.Durum</span>
                    </div>
                    <div class="list-group-item d-flex justify-content-between border-0 px-0">
                        <span class="text-muted">Onay Durumu:</span>
                        <span class="text-@(Model.IsOnayli ? "success" : "danger") fw-bold">
                            <i class="bi @(Model.IsOnayli ? "bi-check-all" : "bi-x")"></i> @(Model.IsOnayli ? "Onaylı" : "Onaysız")
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card border-0 shadow-sm rounded-4 p-4">
                <h6 class="fw-bold mb-4 border-bottom pb-2"><i class="bi bi-person-lines-fill me-2"></i>Bilgileri Güncelle</h6>
                
                <form id="profilForm">
                    <input type="hidden" asp-for="Id" />
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Ad</label>
                            <input type="text" asp-for="Ad" class="form-control rounded-3" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Soyad</label>
                            <input type="text" asp-for="Soyad" class="form-control rounded-3" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">E-Posta Adresi</label>
                            <input type="email" asp-for="Eposta" class="form-control rounded-3" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small fw-bold">Telefon Numarası</label>
                            <input type="text" asp-for="Telefon" class="form-control rounded-3">
                        </div>
                        
                        <div class="col-12 mt-4">
                            <h6 class="fw-bold text-danger border-bottom pb-2 small"><i class="bi bi-key-fill me-2"></i>Güvenlik Ayarları</h6>
                        </div>
                        
                        <div class="col-md-12">
                            <label class="form-label small fw-bold">Yeni Şifre</label>
                            <input type="password" name="YeniSifre" class="form-control rounded-3" placeholder="Değiştirmek istemiyorsanız boş bırakın">
                            <div class="form-text small">Mevcut şifreniz veritabanında <b>SHA256</b> formatında korunmaktadır.</div>
                        </div>

                        <div class="col-12 text-end mt-4">
                            <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                                Değişiklikleri Uygula
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $("#profilForm").submit(function (e) {
        e.preventDefault();
        $.post("/Home/ProfilGuncelle", $(this).serialize(), function (res) {
        if (res.success) {
        Swal.fire('Başarılı', res.message, 'success').then(() => location.reload());
        } else {
        Swal.fire('Hata', res.message, 'error');
        }
        });
        });
    </script>
}