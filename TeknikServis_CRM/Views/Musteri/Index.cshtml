@{
    ViewData["Title"] = "Müşteri Portföyü & Yönetimi";
}

<div class="container-fluid mt-4 px-md-4 pb-5 text-dark">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h2 class="h3 mb-1 text-gray-800 font-weight-bold"><i class="fas fa-users text-primary me-2"></i>Müşteri Portföyü</h2>
            <p class="text-muted mb-0 small text-uppercase fw-bold">Müşteri İlişkileri ve Borç Yönetimi</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <div class="btn-group me-2 shadow-sm">
                <button class="btn btn-outline-primary dropdown-toggle rounded-pill px-3" data-bs-toggle="dropdown">
                    <i class="fas fa-layer-group me-1"></i> Toplu İşlemler
                </button>
                <ul class="dropdown-menu shadow border-0 mt-2">
                    <li><a class="dropdown-item py-2" href="javascript:void(0)" onclick="topluIslemAc('mail')"><i class="fas fa-envelope text-primary me-2"></i>Toplu Mail Gönder</a></li>
                    <li><a class="dropdown-item py-2" href="javascript:void(0)" onclick="topluIslemAc('isEmri')"><i class="fas fa-tasks text-success me-2"></i>Toplu İş Emri Ata</a></li>
                </ul>
            </div>
            <button class="btn btn-primary shadow-sm rounded-pill px-4" onclick="yeniMusteriModal()">
                <i class="fas fa-user-plus me-1"></i> Yeni Müşteri Ekle
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="m-0 font-weight-bold text-dark">Aktif Müşteri Listesi</h6>
            <div class="small text-muted">Seçili: <span id="selectedCount" class="fw-bold text-primary">0</span></div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="tblMusteriler" class="table table-hover align-middle w-100 m-0 text-dark">
                    <thead class="bg-light">
                        <tr class="text-secondary small">
                            <th style="width: 40px;"><input type="checkbox" class="form-check-input" id="chkAll"></th>
                            <th>Müşteri / Firma</th>
                            <th>İletişim Bilgileri</th>
                            <th>Müşteri Tipi</th>
                            <th>Toplam Ciro (₺)</th>
                            <th>Durum</th>
                            <th class="text-center">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody class="small"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlHizliTahsilat" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">
            <div class="modal-header bg-success text-white py-2 border-0">
                <h6 class="modal-title fw-bold small"><i class="fas fa-lira-sign me-2"></i>Hızlı Tahsilat Al</h6>
                <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center text-dark">
                <input type="hidden" id="ht_MusteriId" />
                <h6 class="fw-bold mb-1" id="ht_MusteriAd">...</h6>
                <div class="my-3 text-start">
                    <label class="small fw-bold mb-1 text-muted">Tahsil Edilecek Tutar (₺)</label>
                    <input type="number" id="ht_Tutar" class="form-control form-control-lg fw-bold text-success text-center border-2" placeholder="0.00" step="0.01" />
                    <div class="text-center mt-2"><small class="badge bg-light text-muted border" id="ht_BakiyeBilgi">Bakiye hesaplanıyor...</small></div>
                </div>
                <div class="mb-4 text-start">
                    <label class="small fw-bold mb-1">Ödeme Yöntemi</label>
                    <select id="ht_Yontem" class="form-select form-select-sm rounded-pill bg-light border-0">
                        <option value="Nakit">Nakit</option>
                        <option value="Kredi Kartı">Kredi Kartı</option>
                        <option value="Havale/EFT">Havale/EFT</option>
                    </select>
                </div>
                <button class="btn btn-success w-100 rounded-pill fw-bold shadow" onclick="tahsilatKaydet()">Tahsilatı Onayla</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlIslemTekrari" tabindex="-1" aria-hidden="true" style="z-index: 1080;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg text-dark">
            <div class="modal-header bg-primary text-white border-0 py-2">
                <h6 class="modal-title fw-bold">Hızlı Servis Kaydı</h6>
                <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="hdnIslemMusteriId" />
                <div class="mb-3">
                    <label class="small fw-bold">Cihaz Seçimi</label>
                    <select id="ddlTekrarCihaz" class="form-select border-primary"></select>
                </div>
                <div class="mb-3">
                    <label class="small fw-bold">Arıza Şikayeti</label>
                    <textarea id="txtServisAciklama" class="form-control border-primary" rows="3" placeholder="Arıza detayını buraya yazın..."></textarea>
                </div>
                <button type="button" class="btn btn-primary w-100 rounded-pill shadow fw-bold" onclick="islemTekrariniKaydet()">İŞ EMRİ OLUŞTUR VE BAŞLAT</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlMusteri" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white border-0 py-3">
                <h5 class="modal-title fw-bold" id="modalBaslik"><i class="fas fa-user-plus me-2"></i>Müşteri Bilgileri</h5>
                <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <form id="frmMusteri">
                <div class="modal-body p-4 bg-light text-dark">
                    <input type="hidden" name="Id" id="txtId" value="0" />
                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-header bg-white fw-bold text-primary small">TEMEL BİLGİLER</div>
                                <div class="card-body row g-3">
                                    <div class="col-md-6"><label class="small fw-bold">Ad</label><input type="text" name="Ad" id="txtAd" class="form-control form-control-sm" required /></div>
                                    <div class="col-md-6"><label class="small fw-bold">Soyad</label><input type="text" name="Soyad" id="txtSoyad" class="form-control form-control-sm" required /></div>
                                    <div class="col-md-12"><label class="small fw-bold">Firma Adı</label><input type="text" name="FirmaAdi" id="txtFirmaAdi" class="form-control form-control-sm" /></div>
                                    <div class="col-md-6">
                                        <label class="small fw-bold">Tip</label>
                                        <select name="MusteriTipId" id="ddlMusteriTip" class="form-select form-select-sm">
                                            @foreach (var item in ViewBag.MusteriTipleri)
                                            {
                                                <option value="@item.Id">@item.TipAdi</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="small fw-bold">Durum</label>
                                        <select name="MusteriDurumId" id="ddlMusteriDurum" class="form-select form-select-sm">
                                            @foreach (var item in ViewBag.MusteriDurumlari)
                                            {
                                                <option value="@item.Id">@item.DurumAdi</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-header bg-white fw-bold text-primary small">İLETİŞİM</div>
                                <div class="card-body row g-3">
                                    <div class="col-md-6"><label class="small fw-bold">Telefon</label><input type="text" name="Telefon" id="txtTelefon" class="form-control form-control-sm" required /></div>
                                    <div class="col-md-6"><label class="small fw-bold">E-Posta</label><input type="email" name="Eposta" id="txtEposta" class="form-control form-control-sm" /></div>
                                    <div class="col-md-12"><label class="small fw-bold">Açık Adres</label><textarea name="AcikAdres" id="txtAcikAdres" class="form-control form-control-sm" rows="3"></textarea></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer bg-white border-top">
                    <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-5 shadow">Kaydet</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlFullDetay" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden text-dark">
            <div class="modal-header bg-dark text-white border-0 py-3">
                <h5 class="modal-title fw-bold"><i class="fas fa-id-badge me-2"></i>Müşteri Komuta Merkezi</h5>
                <button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <input type="hidden" id="hdnAktifMusteriId" value="0" />
                <div class="row g-0">
                    <div class="col-md-4 bg-light border-end text-center">
                        <div class="p-4 border-bottom bg-white">
                            <div class="bg-primary text-white d-inline-flex align-items-center justify-content-center rounded-circle mb-3 shadow-sm" style="width:70px; height:70px; font-size:1.5rem;"><i class="fas fa-user"></i></div>
                            <h5 id="fd_AdSoyad" class="fw-bold mb-1">...</h5>
                            <p id="fd_Firma" class="text-muted small mb-1">...</p>
                            <span class="badge bg-success shadow-sm" id="fd_Ciro">0.00 ₺</span>
                        </div>
                        <div class="p-3 text-start small">
                            <div class="mb-4">
                                <div class="mb-2 text-dark"><i class="fas fa-phone text-primary me-2"></i> <span id="fd_Tel"></span></div>
                                <div class="mb-2 text-dark"><i class="fas fa-envelope text-primary me-2"></i> <span id="fd_Mail"></span></div>
                            </div>
                            <div class="d-grid gap-2">
                                <button class="btn btn-primary btn-sm rounded-pill shadow-sm" onclick="islemTekrariModalPopup()"><i class="fas fa-tools me-2"></i>Servis Başlat</button>
                                <button class="btn btn-outline-info btn-sm rounded-pill" onclick="tekilMailAc()"><i class="fas fa-paper-plane me-2"></i>E-Posta Gönder</button>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-8 p-4 bg-white">
                        <ul class="nav nav-tabs border-0 bg-light rounded-pill p-1 mb-3">
                            <li class="nav-item flex-fill text-center"><a class="nav-link active rounded-pill border-0 small fw-bold" data-bs-toggle="tab" href="#tabFinans">Finans</a></li>
                            <li class="nav-item flex-fill text-center"><a class="nav-link rounded-pill border-0 small fw-bold" data-bs-toggle="tab" href="#tabCihazlar">Cihazlar</a></li>
                            <li class="nav-item flex-fill text-center"><a class="nav-link rounded-pill border-0 small fw-bold" data-bs-toggle="tab" href="#tabNotlar">Notlar</a></li>
                        </ul>
                        <div class="tab-content" style="max-height: 400px; overflow-y: auto;">
                            <div class="tab-pane fade show active" id="tabFinans"><table class="table table-sm table-hover"><tbody id="lstFinans"></tbody></table></div>
                            <div class="tab-pane fade" id="tabCihazlar"><div class="row g-2" id="lstCihazlar"></div></div>
                            <div class="tab-pane fade" id="tabNotlar">
                                <div class="input-group input-group-sm mb-3">
                                    <textarea id="txtYeniNot" class="form-control border-primary" placeholder="Yeni not ekle..."></textarea>
                                    <button class="btn btn-primary" onclick="musteriyeNotEkle()">Kaydet</button>
                                </div>
                                <div id="lstNotlar" class="list-group list-group-flush"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="mdlTopluIslem" tabindex="-1" aria-hidden="true" style="z-index: 1070;">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg text-dark">
            <div class="modal-header bg-dark text-white border-0 py-2"><h6 class="modal-title fw-bold" id="topluIslemBaslik">Toplu İşlem</h6><button type="button" class="btn-close btn-close-white shadow-none" data-bs-dismiss="modal"></button></div>
            <div class="modal-body p-4">
                <div id="divTeknisyenSecimi" class="mb-3 d-none">
                    <label class="small fw-bold">Görevlendirilecek Teknisyen</label>
                    <select id="ddlTopluTeknisyen" class="form-select border-primary">
                        @if (ViewBag.Teknisyenler != null)
                        {
                            foreach (var t in ViewBag.Teknisyenler)
                            {
                                <option value="@t.Id">@t.AdSoyad</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-3"><label class="small fw-bold" id="lblKonu">Konu</label><input type="text" id="txtTopluKonu" class="form-control border-primary"></div>
                <div class="mb-3"><label class="small fw-bold" id="lblMesaj">Mesaj İçeriği</label><textarea id="txtTopluMesaj" class="form-control border-primary" rows="4"></textarea></div>
                <div class="alert alert-info py-2 small border-0"><i class="fas fa-info-circle me-1"></i> <span id="spnSeciliSayisi">0</span> kişi seçildi.</div>
                <button class="btn btn-primary w-100 rounded-pill shadow" onclick="topluIslemiTamamla()">İşlemi Onayla</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        let table;
        let seciliIslemTipi = "";

        $(document).ready(function () {
        table = $('#tblMusteriler').DataTable({
        "ajax": { "url": "/Musteri/GetMusteriListesi", "dataSrc": "" },
        "columns": [
        { "data": "id", "orderable": false, "render": id => `<input type="checkbox" class="form-check-input chkMusteri" value="${id}" onchange="checkCount()">` },
        { "data": null, "render": d => `<div class="fw-bold text-primary cursor-pointer" onclick="fullDetayGetir(${d.id})">${d.adSoyad}</div><div class="small text-muted">${d.firmaAdi || '-'}</div>` },
        { "data": null, "render": d => `<div class="small"><i class="fas fa-phone me-1 text-primary"></i>${d.telefon}</div><div class="small opacity-75">${d.eposta || ''}</div>` },
        { "data": "tipAdi", "render": d => `<span class="badge bg-soft-primary text-primary px-3">${d}</span>` },
        { "data": "toplamTahsilat", "render": d => `<span class="fw-bold">₺${parseFloat(d).toLocaleString('tr-TR')}</span>` },
        { "data": "durumAdi", "render": (d, t, r) => `<span class="badge" style="background-color:${r.renkKodu}">${d}</span>` },
        {
        "data": "id", "className": "text-center", "render": (id, t, r) => `
        <div class="btn-group shadow-sm rounded-pill overflow-hidden bg-white">
        <button class="btn btn-sm btn-white text-success border-end px-2" onclick="hizliTahsilatAc(${id}, '${r.adSoyad}')" title="Tahsilat Al"><i class="fas fa-lira-sign"></i></button>
        <button class="btn btn-sm btn-white text-warning border-end px-2" onclick="musteriDuzenle(${id})"><i class="fas fa-pencil-alt"></i></button>
        <button class="btn btn-sm btn-white text-danger px-2" onclick="musteriSil(${id})"><i class="fas fa-trash"></i></button>
        </div>`
        }
        ],
        "language": { "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/tr.json" }
        });

        $('#chkAll').click(function () { $('.chkMusteri').prop('checked', this.checked); checkCount(); });
        });

        // HIZLI TAHSİLAT: Borç bilgisini çekip otomatik yazar
        function hizliTahsilatAc(id, ad) {
        $('#ht_MusteriId').val(id);
        $('#ht_MusteriAd').text(ad);
        $('#ht_BakiyeBilgi').text("Bakiye sorgulanıyor...");
        $('#ht_Tutar').val("");

        // GetFullDetay metodundan güncel borç/bakiye verisini alıyoruz
        $.get('/Musteri/GetFullDetay/' + id, function (res) {
        if (res.success) {
        let bakiye = parseFloat(res.kalanBakiye || 0);
        if (bakiye > 0) {
        $('#ht_Tutar').val(bakiye.toFixed(2));
        $('#ht_BakiyeBilgi').html(`<i class="fas fa-info-circle me-1"></i>Bekleyen Ödeme: <b>₺${bakiye.toLocaleString('tr-TR')}</b>`);
        } else {
        $('#ht_Tutar').val("");
        $('#ht_BakiyeBilgi').text("Müşterinin bekleyen borcu bulunmuyor.");
        }
        }
        $('#mdlHizliTahsilat').modal('show');
        });
        }

        function tahsilatKaydet() {
        let data = { musteriId: $('#ht_MusteriId').val(), tutar: $('#ht_Tutar').val(), yontem: $('#ht_Yontem').val() };
        if (!data.tutar || data.tutar <= 0) { Swal.fire("Uyarı", "Geçerli bir tutar girin.", "warning"); return; }
        $.post('/Musteri/HizliTahsilat', data, function (res) {
        if (res.success) {
        $('#mdlHizliTahsilat').modal('hide');
        table.ajax.reload(null, false);
        Swal.fire("Başarılı", "Tahsilat sisteme işlendi.", "success");
        }
        });
        }

        // FULL DETAY
        function fullDetayGetir(id) {
        $.get('/Musteri/GetFullDetay/' + id, function (res) {
        if (res.success) {
        let m = res.musteri;
        $('#hdnAktifMusteriId').val(m.id);
        $('#fd_AdSoyad').text(m.adSoyad);
        $('#fd_Firma').text(m.firmaAdi || "Bireysel");
        $('#fd_Ciro').text(`₺${res.toplamCiro.toLocaleString('tr-TR')}`);
        $('#fd_Tel').text(m.telefon); $('#fd_Mail').text(m.eposta || "-");

        let fHtm = "";
        res.finans.forEach(f => { fHtm += `<tr><td>${f.tarih}</td><td>${f.islemTipi}</td><td class="text-end fw-bold text-success">₺${parseFloat(f.tutar).toLocaleString('tr-TR')}</td></tr>`; });
        $('#lstFinans').html(fHtm || "<tr><td colspan='3' class='text-center py-3'>Hareket yok.</td></tr>");

        let cHtm = "";
        res.cihazlar.forEach(c => { cHtm += `<div class="col-6 p-1"><div class="p-2 border rounded-3 bg-white text-center fw-bold small text-dark">${c.marka} ${c.model}</div></div>`; });
        $('#lstCihazlar').html(cHtm || "<div class='p-3 text-muted'>Cihaz kaydı yok.</div>");

        let nHtm = "";
        res.notlar.forEach(n => { nHtm += `<div class="list-group-item bg-light border-0 rounded-3 mb-2 small text-dark"><b>${n.tarih}:</b> ${n.notIcerigi}</div>`; });
        $('#lstNotlar').html(nHtm || "<div class='text-muted small'>Not bulunmuyor.</div>");

        $('#mdlFullDetay').modal('show');
        }
        });
        }

        // SERVİS BAŞLAT
        function islemTekrariModalPopup() {
        let id = $('#hdnAktifMusteriId').val();
        $('#hdnIslemMusteriId').val(id);
        $.get('/Musteri/GetFullDetay/' + id, function(res) {
        let opts = ""; res.cihazlar.forEach(c => { opts += `<option value="${c.id}">${c.marka} ${c.model}</option>`; });
        $('#ddlTekrarCihaz').html(opts || "<option value=''>Cihaz Bulunmuyor</option>");
        $('#mdlIslemTekrari').modal('show');
        });
        }

        function islemTekrariniKaydet() {
        let data = {
        MusteriId: $('#hdnIslemMusteriId').val(),
        CihazId: $('#ddlTekrarCihaz').val(),
        SikayetAciklamasi: $('#txtServisAciklama').val()
        };
        if(!data.CihazId) { Swal.fire("Hata", "Önce cihaz eklenmelidir.", "error"); return; }
        $.post('/Musteri/HizliServisKaydiAc', data, function (res) {
        if (res.success) {
        $('#mdlIslemTekrari').modal('hide');
        Swal.fire("Başarılı", "İş Emri Oluşturuldu.", "success");
        }
        });
        }

        // STANDARTLAR
        function yeniMusteriModal() { $('#frmMusteri')[0].reset(); $('#txtId').val(0); $('#modalBaslik').text("Yeni Müşteri Ekle"); $('#mdlMusteri').modal('show'); }
        function musteriDuzenle(id) {
        $.get('/Musteri/GetMusteri/' + id, function (res) {
        if (res.musteri) {
        let m = res.musteri;
        $('#txtId').val(m.id); $('#txtAd').val(m.ad); $('#txtSoyad').val(m.soyad);
        $('#txtFirmaAdi').val(m.firmaAdi); $('#txtTelefon').val(m.telefon);
        $('#txtEposta').val(m.eposta); $('#ddlMusteriTip').val(m.musteriTipId);
        $('#ddlMusteriDurum').val(m.musteriDurumId);
        if (res.adres) $('#txtAcikAdres').val(res.adres.acikAdres);
        $('#modalBaslik').text("Müşteri Düzenle"); $('#mdlMusteri').modal('show');
        }
        });
        }
        function musteriSil(id) {
        Swal.fire({ title: 'Silinsin mi?', icon: 'warning', showCancelButton: true }).then((r) => { if (r.isConfirmed) $.post('/Musteri/Sil/' + id, function () { table.ajax.reload(); }); });
        }
        function checkCount() { $('#selectedCount').text($(".chkMusteri:checked").length); }
        function musteriyeNotEkle() {
        let id = $('#hdnAktifMusteriId').val();
        let not = $('#txtYeniNot').val();
        if (!not) return;
        $.post('/Musteri/NotEkle', { MusteriId: id, NotIcerigi: not }, function (res) { if (res.success) { $('#txtYeniNot').val(''); fullDetayGetir(id); } });
        }

        // TOPLU İŞLEM
        function topluIslemAc(tip) {
        if ($(".chkMusteri:checked").length === 0) { Swal.fire("Uyarı", "Müşteri seçmelisiniz.", "warning"); return; }
        seciliIslemTipi = tip;
        $('#divTeknisyenSecimi').toggleClass('d-none', tip !== 'isEmri');
        $('#topluIslemBaslik').text(tip === 'mail' ? "Toplu Mail Gönderimi" : "Toplu İş Emri Ata");
        $('#mdlTopluIslem').modal('show');
        }
        function topluIslemiTamamla() {
        let idler = []; $(".chkMusteri:checked").each(function(){ idler.push(parseInt($(this).val())); });
        let data = { HedefIdler: idler, Konu: $('#txtTopluKonu').val(), Mesaj: $('#txtTopluMesaj').val(), TeknisyenId: $('#ddlTopluTeknisyen').val() };
        $.post(seciliIslemTipi === 'mail' ? '/Iletisim/MesajGonder' : '/Iletisim/TopluIsEmriAtay', data, function (res) {
        if (res.success) { $('#mdlTopluIslem').modal('hide'); Swal.fire("Başarılı", "İşlem tamamlandı.", "success"); }
        });
        }
        function tekilMailAc() {
        let id = $('#hdnAktifMusteriId').val();
        $('.chkMusteri').prop('checked', false);
        $(`.chkMusteri[value="${id}"]`).prop('checked', true);
        topluIslemAc('mail');
        }
    </script>

