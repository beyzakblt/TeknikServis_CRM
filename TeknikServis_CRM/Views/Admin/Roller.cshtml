@model List<TeknikServis_CRM.Models.Roller>
@{
    ViewData["Title"] = "Rol ve Yetki Yönetimi";
    var yetkiListesi = ViewBag.YetkiListesi as List<TeknikServis_CRM.Models.Yetkiler> ?? new List<Yetkiler>();
}

<style>
    .role-card { transition: all 0.3s ease; border: 1px solid #eee; }
    .role-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
    .permission-table thead th { background-color: #f8f9fa; font-size: 0.7rem; letter-spacing: 1px; color: #6c757d; text-transform: uppercase; }
    .form-check-input:checked { background-color: #0d6efd; border-color: #0d6efd; }
    .sticky-table-header { position: sticky; top: 0; z-index: 1020; background: white; }
    .table-hover tbody tr:hover { background-color: rgba(13, 110, 253, 0.02); }
    /* Sütun seçici ikonları için stil */
    .column-select { cursor: pointer; color: #0d6efd; font-size: 0.8rem; margin-left: 5px; }
    .column-select:hover { color: #0a58ca; }
</style>

<div class="container-fluid py-4">
    <div class="row align-items-center mb-4">
        <div class="col">
            <h4 class="fw-bold mb-1 text-dark">Rol ve Yetki Tanımları</h4>
            <p class="text-muted small">Sistemdeki rollerin modül bazlı yetki sınırlarını buradan belirleyebilirsiniz.</p>
        </div>
        <div class="col-auto">
            <button class="btn btn-primary rounded-3 px-4 py-2 shadow-sm fw-bold border-0" onclick="yeniRolModal()">
                <i class="bi bi-shield-lock-fill me-2"></i>Yeni Rol Tanımla
            </button>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="table-responsive">
            <table class="table align-middle mb-0 table-hover">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">ROL TANIMI</th>
                        <th>ROL KODU</th>
                        <th>DURUM</th>
                        <th class="text-end pe-4">İŞLEMLER</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="fw-bold text-dark">@item.RolAdi</div>
                                </td>
                                <td><span class="badge bg-dark bg-opacity-10 text-dark px-3">@item.RolKodu</span></td>
                                <td>
                                    <span class="badge @(item.Durum == "Aktif" ? "bg-success" : "bg-danger") bg-opacity-10 text-@(item.Durum == "Aktif" ? "success" : "danger") px-3">
                                        @item.Durum
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm border rounded-pill bg-white px-2">
                                        <button onclick="editRol(@item.Id)" class="btn btn-sm border-0 text-primary" title="Düzenle"><i class="bi bi-pencil-fill"></i></button>
                                        <button onclick="deleteRol(@item.Id)" class="btn btn-sm border-0 text-danger" title="Sil"><i class="bi bi-trash3-fill"></i></button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">Henüz tanımlanmış bir rol bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="rolModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pt-4 px-4">
                <h5 class="fw-bold mb-0" id="modalBaslik">Rol Yetkilendirme</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="rolForm">
                <div class="modal-body p-4">
                    <input type="hidden" name="Id" id="rId" value="0">
                    
                    <div class="row g-3 mb-4 bg-light p-3 rounded-4 mx-0 border">
                        <div class="col-md-5">
                            <label class="form-label small fw-bold text-muted text-uppercase">Rol Adı</label>
                            <input type="text" name="RolAdi" id="rRolAdi" class="form-control border-0 shadow-none px-3 py-2 rounded-3" placeholder="Örn: Saha Teknisyeni" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-muted text-uppercase">Rol Kodu (SLUG)</label>
                            <input type="text" name="RolKodu" id="rRolKodu" class="form-control border-0 shadow-none px-3 py-2 rounded-3 text-uppercase" placeholder="TEKNISYEN" required>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label small fw-bold text-muted text-uppercase">Durum</label>
                            <select name="Durum" id="rDurum" class="form-select border-0 shadow-none px-3 py-2 rounded-3">
                                <option value="Aktif">Aktif</option>
                                <option value="Pasif">Pasif</option>
                            </select>
                        </div>
                    </div>

                    <h6 class="fw-bold px-2 mb-3 text-dark">
                        <i class="bi bi-grid-3x3-gap-fill me-2 text-primary"></i>Modül Yetki Matrisi
                    </h6>
                    <div class="table-responsive border rounded-4 shadow-sm" style="max-height: 500px;">
                        <table class="table align-middle mb-0 permission-table">
                            <thead class="sticky-table-header shadow-sm">
                                <tr>
                                    <th class="ps-4 py-3">MODÜL / FONKSİYON</th>
                                    <th class="text-center py-3">GÖRÜNTÜLE <i class="bi bi-check2-all column-select" onclick="toggleColumn('check-g')" title="Tümünü Seç/Kaldır"></i></th>
                                    <th class="text-center py-3">EKLEME <i class="bi bi-check2-all column-select" onclick="toggleColumn('check-e')" title="Tümünü Seç/Kaldır"></i></th>
                                    <th class="text-center py-3">GÜNCELLEME <i class="bi bi-check2-all column-select" onclick="toggleColumn('check-d')" title="Tümünü Seç/Kaldır"></i></th>
                                    <th class="text-center py-3">SİLME <i class="bi bi-check2-all column-select" onclick="toggleColumn('check-s')" title="Tümünü Seç/Kaldır"></i></th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 0; i < yetkiListesi.Count; i++)
                                {
                                    var y = yetkiListesi[i];
                                    <tr>
                                        <td class="ps-4">
                                            <input type="hidden" name="YetkiMatrisi[@i].YetkiId" value="@y.Id" />
                                            <div class="fw-bold text-dark">@y.YetkiAdi</div>
                                            <div class="small text-muted" style="font-size: 0.75rem;">Modül: @y.ModulAdi</div>
                                        </td>
                                        <td class="text-center">
                                            <input type="checkbox" name="YetkiMatrisi[@i].GoruntulemeVarMi" value="true" class="form-check-input check-g" data-yetkiid="@y.Id">
                                        </td>
                                        <td class="text-center">
                                            <input type="checkbox" name="YetkiMatrisi[@i].EklemeVarMi" value="true" class="form-check-input check-e" data-yetkiid="@y.Id">
                                        </td>
                                        <td class="text-center">
                                            <input type="checkbox" name="YetkiMatrisi[@i].GuncellemeVarMi" value="true" class="form-check-input check-d" data-yetkiid="@y.Id">
                                        </td>
                                        <td class="text-center">
                                            <input type="checkbox" name="YetkiMatrisi[@i].SilmeVarMi" value="true" class="form-check-input check-s" data-yetkiid="@y.Id">
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer border-0 pb-4 px-4 bg-light bg-opacity-50">
                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold" data-bs-dismiss="modal">İptal</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold shadow-sm">
                        <i class="bi bi-check-circle-fill me-2"></i>Değişiklikleri Kaydet
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // Sütun bazlı tümünü seçme/kaldırma
        function toggleColumn(className) {
            const checkboxes = $(`.${className}`);
            const allChecked = Array.from(checkboxes).every(cb => cb.checked);
            checkboxes.prop('checked', !allChecked);
        }

        function yeniRolModal() {
            $("#rolForm")[0].reset();
            $("#rId").val(0);
            $(".form-check-input").prop("checked", false);
            $("#modalBaslik").text("Yeni Rol Tanımla");
            $("#rolModal").modal("show");
        }

        function editRol(id) {
            $("#rolForm")[0].reset();
            $(".form-check-input").prop("checked", false);
            
            $.get("/Admin/RolKaydet/" + id, function (data) {
                if(data) {
                    $("#rId").val(data.rol.id);
                    $("#rRolAdi").val(data.rol.rolAdi);
                    $("#rRolKodu").val(data.rol.rolKodu);
                    $("#rDurum").val(data.rol.durum);
                    $("#modalBaslik").text("Rol Düzenle: " + data.rol.rolAdi);

                    if (data.yetkiler && data.yetkiler.length > 0) {
                        data.yetkiler.forEach(function (y) {
                            $(`.check-g[data-yetkiid='${y.yetkiId}']`).prop("checked", y.goruntulemeVarMi);
                            $(`.check-e[data-yetkiid='${y.yetkiId}']`).prop("checked", y.eklemeVarMi);
                            $(`.check-d[data-yetkiid='${y.yetkiId}']`).prop("checked", y.guncellemeVarMi);
                            $(`.check-s[data-yetkiid='${y.yetkiId}']`).prop("checked", y.silmeVarMi);
                        });
                    }
                    $("#rolModal").modal("show");
                }
            }).fail(function() {
                Swal.fire('Hata', 'Veriler yüklenirken bir sorun oluştu.', 'error');
            });
        }

        $("#rolForm").submit(function (e) {
            e.preventDefault();
            let formData = $(this).serialize();

            $.post("/Admin/RolKaydet", formData, function (res) {
                if (res.success) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Başarılı',
                        text: res.message,
                        timer: 2000,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    Swal.fire('Hata', res.message, 'error');
                }
            });
        });

        function deleteRol(id) {
            Swal.fire({
                title: 'Rolü silmek/pasif yapmak istediğinize emin misiniz?',
                text: "Bu rol pasif duruma getirilecek ve bu role sahip kullanıcıların yetkileri etkilenebilir!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Evet, pasif yap!',
                cancelButtonText: 'Vazgeç'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post("/Admin/RolSil", { id: id }, function (res) {
                        if (res.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'İşlem Başarılı',
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => location.reload());
                        } else {
                            Swal.fire('Hata', res.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}